# Copy this file to Server/shared/.env and fill in real values.
# api_service and worker_service both load this file (in addition to their
# own .env, if present) via shared.config.get_settings().

# --- MongoDB (Atlas) ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGO_DB_NAME=data_analyzer

# --- Redis (Upstash for prod, local docker for dev) ---
REDIS_URL=redis://localhost:6379/0

# --- AWS S3 ---
AWS_ACCESS_KEY=
AWS_ACCESS_SECRET=
AWS_REGION=us-east-1
AWS_BUCKET=data-analyzer

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth / JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Usage limits (free tier) ---
FREE_TIER_MESSAGES=20
FREE_TIER_CHARTS=4
FREE_TIER_REPORTS=2

# --- Observability ---
# In docker-compose.yml these are already set via `environment:` (pointing
# at the loki/langfuse-web services on the compose network) - only fill
# these in here if running api_service/worker_service as bare processes
# outside docker compose.
LOG_LEVEL=INFO
ENVIRONMENT=development
# http://<host>:3100/loki/api/v1/push - leave blank to disable Loki shipping
# and log to console only (see shared/logging_config.py).
LOKI_URL=

# Self-hosted Langfuse, api_service side (see docker-compose.yml + root
# .env.example for the Langfuse stack itself). The actual per-LLM-call
# tracing reads its OWN copy of these two keys from
# Server/analyzerEngine/.env.example instead (see
# llm_provider/langfuse_wrapper.py's docstring for why) - this copy is for
# shared/observability.py's get_langfuse_client(), currently unused but
# available if api_service ever wants to push something to Langfuse
# directly (e.g. logging user thumbs-up/down feedback as a Langfuse score).
# Same values either way - either the ones you chose in the root .env's
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY/_SECRET_KEY (auto-provisioned on first
# boot), or the ones the Langfuse UI generates if you signed up manually
# instead. One project, same two keys, copied into both files.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
