# Copy this file to Server/shared/.env and fill in real values.
# api_service and worker_service both load this file (in addition to their
# own .env, if present) via shared.config.get_settings().

# --- MongoDB (Atlas) ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGO_DB_NAME=data_analyzer

# --- Redis (Upstash for prod, local docker for dev) ---
REDIS_URL=redis://localhost:6379/0

# --- Cloudflare R2 (S3-compatible) ---
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=data-analyzer
# Optional: public/base URL if the bucket is served through a custom domain
R2_PUBLIC_BASE_URL=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth / JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Usage limits (free tier) ---
FREE_TIER_MESSAGES=20
FREE_TIER_CHARTS=4
FREE_TIER_REPORTS=2
